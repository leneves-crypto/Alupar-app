rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function profilePath(uid) { return /databases/$(database)/documents/profiles/$(uid); }
    function hasProfile() { return exists(profilePath(request.auth.uid)); }
    function getProfile() { return get(profilePath(request.auth.uid)).data; }
    function getRole() { return hasProfile() ? getProfile().role : 'none'; }
    
    function isAdmin() { return getRole() == 'admin'; }
    function isEngineer() { return getRole() in ['admin', 'engineer', 'coordinator']; }
    function isTST() { return getRole() in ['admin', 'tst']; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Phase 4: Drafting ---

    // [Profiles]
    function isValidProfile(data) {
      return data.role in ['admin', 'engineer', 'tst', 'team', 'coordinator'] &&
             data.name is string && data.name.size() <= 128 &&
             data.uid == request.auth.uid;
    }
    match /profiles/{uid} {
      allow get: if isSignedIn();
      allow list: if isEngineer();
      allow create: if isOwner(uid) && isValidProfile(incoming());
      allow update: if isOwner(uid) && isValidProfile(incoming()) && 
                    incoming().role == existing().role; // Role is immutable after creation by user
    }

    // [Tasks]
    match /tasks/{taskId} {
      allow list, get: if isSignedIn();
      allow create: if isEngineer();
      allow update: if isEngineer() || (
        isSignedIn() && hasProfile() &&
        // Action: Grounding Confirmation
        incoming().diff(existing()).affectedKeys().hasOnly(['groundingConfirmed', 'updatedAt']) &&
        incoming().groundingConfirmed.keys().hasAll(existing().groundingConfirmed.keys()) &&
        incoming().groundingConfirmed[string(getProfile().teamNumber)] == true
      );
    }

    // [Checklists]
    function isValidChecklist(data) {
      return data.taskId is string &&
             data.teamId is int &&
             data.timestamp == request.time &&
             data.authorUid == request.auth.uid;
    }
    match /checklists/{checklistId} {
      allow get: if isSignedIn() && (isEngineer() || resource.data.authorUid == request.auth.uid);
      allow list: if isSignedIn() && (
        isEngineer() || 
        (resource.data.authorUid == request.auth.uid)
      );
      allow create: if isSignedIn() && isValidChecklist(incoming()) && (
        isEngineer() || (hasProfile() && incoming().teamId == getProfile().teamNumber)
      );
      allow update: if isEngineer(); // Only engineers can correct checklists
    }

    // [Releases]
    match /releases/{releaseId} {
      allow get, list: if isSignedIn();
      allow create, update: if isEngineer();
      allow delete: if isAdmin();
    }

    // [Safety Alerts]
    function isValidSafetyAlert(data) {
      return data.reporterUid == request.auth.uid &&
             data.authorUid == request.auth.uid &&
             data.timestamp == request.time &&
             data.status == 'pending';
    }
    match /safety_alerts/{alertId} {
      allow get, list: if isSignedIn() && (isTST() || isEngineer() || resource.data.authorUid == request.auth.uid);
      allow create: if isSignedIn() && isValidSafetyAlert(incoming());
      allow update: if isEngineer() || (isTST() && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }

    // [System Test]
    match /system_test/connection {
      allow read, write: if isSignedIn();
    }
  }
}
